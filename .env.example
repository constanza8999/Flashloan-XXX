# =============================================================================
# FlashArbitrage Backend Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The server will auto-load .env on startup (requires python-dotenv).
# =============================================================================

# ─── REQUIRED: Blockchain Relayer Keys ─────────────────────────────────────
# These are the private keys of the FlashArbitrage contract owners.
# Used to sign withdraw/sweep transactions on each chain.
# Format: 0x + 64 hex characters (without the 0x prefix is also accepted)

ETH_RELAYER_KEY=""
BSC_RELAYER_KEY=""
POLYGON_RELAYER_KEY=""
ARBITRUM_RELAYER_KEY=""

# ─── OPTIONAL: SMTP Email Delivery ─────────────────────────────────────────
# Required for sending license keys to users after purchase.
# Gmail example (enable App Passwords):
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourname@gmail.com
#   SMTP_PASS=your-app-password

SMTP_SERVER=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ─── OPTIONAL: Server Settings ─────────────────────────────────────────────

# Port to run the server on (default: 8000)
PORT="8000"

# ─── NOTES ─────────────────────────────────────────────────────────────────
# - Never commit your .env file to git (it's already in .gitignore)
# - Only .env.example should be committed (no secrets)
# - Private keys can also be passed per-request in the API body,
#   but setting them as env vars is more secure
# - For production, use a proper database instead of in-memory storage
#
# Required Python packages:
#   pip install fastapi uvicorn web3 eth-account python-dotenv
